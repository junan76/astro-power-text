---
import { siteConfig } from "../config/site";
import { withBase } from "../lib/url";

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-shell-wide site-footer-inner">
		<div>&copy; {year} {siteConfig.author.name}</div>
		<div class="footer-links">
			{siteConfig.socialLinks.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
		</div>
	</div>
</footer>
