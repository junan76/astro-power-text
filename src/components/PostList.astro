---
import { formatCompactDate, formatDate, slugifyTag, truncate } from "../lib/content";

type PostItem = {
	title: string;
	description: string;
	date: Date;
	href: string;
	tags?: string[];
};

type Props = {
	posts: PostItem[];
	empty?: string;
	variant?: "default" | "compact";
};

const { posts, empty = "No posts yet.", variant = "default" } = Astro.props;
---

{
	posts.length === 0 ? (
		<p class="muted">{empty}</p>
	) : variant === "compact" ? (
		<ul class="list-plain terminal-list">
			{posts.map((post) => (
				<li class="terminal-row">
					<time class="terminal-date" datetime={post.date.toISOString()}>{formatCompactDate(post.date)}</time>
					<span>
						<a class="terminal-link" href={post.href} data-description={truncate(post.description)}>
							{post.title}
						</a>
					</span>
				</li>
			))}
		</ul>
	) : (
		<ul class="list-plain post-list">
			{posts.map((post) => (
				<li class="post-item">
					<h3 class="post-title"><a href={post.href}>{post.title}</a></h3>
					<div class="post-meta">{formatDate(post.date)}</div>
					<p class="muted">{post.description}</p>
					{post.tags && post.tags.length > 0 && (
						<div class="tag-row">
							{post.tags.map((tag) => <a class="tag" href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>)}
						</div>
					)}
				</li>
			))}
		</ul>
	)
}
