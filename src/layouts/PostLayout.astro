---
import BaseLayout from "./BaseLayout.astro";
import { formatDate, slugifyTag } from "../lib/content";

type Props = {
	title: string;
	description: string;
	date: Date;
	updated?: Date;
	tags?: string[];
	command?: string;
};

const { title, description, date, updated, tags = [], command = "$ cat ./post.md" } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<article class="article">
		<header class="article-header">
			<p class="terminal-command">{command}</p>
			<h1>{title}</h1>
			<p class="post-meta">
				Published {formatDate(date)}
				{updated && <> · Updated {formatDate(updated)}</>}
			</p>
			{tags.length > 0 && (
				<div class="tag-row">
					{tags.map((tag) => <a class="tag" href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>)}
				</div>
			)}
		</header>
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>
