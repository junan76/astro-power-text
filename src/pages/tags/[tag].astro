---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import {
	getPostPath,
	getProjectArticlePath,
	isProjectIndex,
	isPublishedPost,
	slugifyTag,
	sortByDateDesc,
} from "../../lib/content";

export async function getStaticPaths() {
	const regularPosts = (await getCollection("posts")).filter(isPublishedPost);
	const projectPosts = (await getCollection("projects")).filter((post) => isPublishedPost(post) && !isProjectIndex(post));
	const slugToTag = new Map<string, string>();
	for (const entry of [...regularPosts, ...projectPosts]) {
		for (const tag of entry.data.tags) {
			const slug = slugifyTag(tag);
			if (!slugToTag.has(slug)) slugToTag.set(slug, tag);
		}
	}
	return [...slugToTag].map(([slug, tag]) => ({ params: { tag: slug }, props: { tag } }));
}

const { tag } = Astro.props;
const targetSlug = slugifyTag(tag);
const regularPosts = (await getCollection("posts")).filter(isPublishedPost).map((post) => ({
	entry: post,
	href: getPostPath(post),
}));
const projectPosts = (await getCollection("projects"))
	.filter((post) => isPublishedPost(post) && !isProjectIndex(post))
	.map((post) => ({ entry: post, href: getProjectArticlePath(post) }));
const posts = sortByDateDesc(
	[...regularPosts, ...projectPosts]
		.filter(({ entry }) => entry.data.tags.some((entryTag) => slugifyTag(entryTag) === targetSlug))
		.map(({ entry, href }) => ({
			title: entry.data.title,
			description: entry.data.description,
			date: entry.data.date,
			href,
			tags: entry.data.tags,
		})),
);
---

<BaseLayout title={`tag: ${tag}`}>
	<div class="terminal-page">
		<p class="terminal-command">$ grep -r "tag: {tag}" ./posts ./projects</p>
		<div class="terminal-scroll">
			<section class="home-section">
				<PostList posts={posts} variant="compact" />
			</section>
		</div>
	</div>
</BaseLayout>
