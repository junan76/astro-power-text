---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTagPath, isProjectIndex, isPublishedPost, slugifyTag } from "../../lib/content";
import { withBase } from "../../lib/url";

const allPosts = [
	...(await getCollection("posts")).filter(isPublishedPost),
	...(await getCollection("projects")).filter((post) => isPublishedPost(post) && !isProjectIndex(post)),
];

type TagBucket = { display: string; count: number };
const tagBuckets = new Map<string, TagBucket>();
for (const post of allPosts) {
	for (const tag of post.data.tags) {
		const slug = slugifyTag(tag);
		const bucket = tagBuckets.get(slug);
		if (bucket) bucket.count += 1;
		else tagBuckets.set(slug, { display: tag, count: 1 });
	}
}

const tags = [...tagBuckets.values()].sort(
	(a, b) => b.count - a.count || a.display.localeCompare(b.display),
);
---

<BaseLayout title="tags">
	<div class="terminal-page">
		<p class="terminal-command">$ ls ./tags --sort=count</p>
		<div class="terminal-scroll">
			<ul class="list-plain terminal-count-list">
				{tags.map(({ display, count }) => (
					<li>
						<a class="terminal-count-row" href={withBase(getTagPath(display))}>
							<span>{display}</span>
							<span class="terminal-count">{count}</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	</div>
</BaseLayout>
